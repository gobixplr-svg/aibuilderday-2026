{
  "name": "roof-recon-reveal-video",
  "version": "0.1.0",
  "description": "Apple-style 15s product reveal video for Roof Recon. Self-contained — does not affect parent project.",
  "type": "module",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts Reveal30 out/reveal-37s.mp4 --codec=h264 --crf=18 --pixel-format=yuv420p --audio-codec=aac --audio-bitrate=192k",
    "render-v1": "remotion render src/index.ts Reveal15 out/reveal-15s.mp4 --codec=h264 --crf=18 --pixel-format=yuv420p --audio-codec=aac --audio-bitrate=192k",
    "render-gif": "ffmpeg -y -i out/reveal-30s.mp4 -vf \"fps=20,scale=1024:-1:flags=lanczos\" -loop 0 out/reveal-30s.gif"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/fonts": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.0"
  }
}
