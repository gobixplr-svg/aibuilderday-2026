# Copy to .env.local and fill in.
# .env.local is gitignored.

# Anthropic — for vision (pitch, footprint, line items)
ANTHROPIC_API_KEY=
# Google Maps — for geocoding + Static Maps satellite imagery
# Enable: Geocoding API, Maps Static API
# Console: https://console.cloud.google.com/apis/dashboard
GOOGLE_MAPS_API_KEY=AIza...

# Optional: set DEBUG=1 to print stack traces on errors
# DEBUG=1
